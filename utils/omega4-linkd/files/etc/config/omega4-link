	option udp_dest '127.0.0.1:14552'

config omega4-mavlink 'air_serial'
	option enabled '0'
	option serial '/dev/ttyS1'
	option baud '57600'
	option udp_listen '14552'
	option udp_dest '127.0.0.1:14551'

