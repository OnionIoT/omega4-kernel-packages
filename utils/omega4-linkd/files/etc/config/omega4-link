config omega4-link 'main'
	option enabled '0'
	option mode 'rx'
	option iface 'wlan0'
	option setup '1'
	option freq '5180'
	option ht_mode 'HT20'
	option stream '255'
	option udp_listen '5601'
	option udp_dest '127.0.0.1:5602'
	option interval_ms '1000'
	option count '0'

config omega4-link 'mav_air_tx'
	option enabled '0'
	option mode 'tx'
	option iface 'wlan0'
	option setup '1'
	option freq '5180'
	option ht_mode 'HT20'
	option stream '2'
	option udp_listen '14551'

config omega4-link 'mav_air_rx'
	option enabled '0'
	option mode 'rx'
	option iface 'wlan0'
	option setup '0'
	option freq '5180'
	option ht_mode 'HT20'
