#!/bin/sh /etc/rc.common

START=98
STOP=10
USE_PROCD=1

start_link_instance() {
	local section="$1"
	local enabled mode iface setup freq ht_mode stream udp_listen udp_dest interval_ms count

	config_get_bool enabled "$section" enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get mode "$section" mode rx
	config_get iface "$section" iface wlan0
	config_get_bool setup "$section" setup 0
	config_get freq "$section" freq 5180
	config_get ht_mode "$section" ht_mode HT20
	config_get stream "$section" stream 255
	config_get udp_listen "$section" udp_listen 5601
	config_get udp_dest "$section" udp_dest 127.0.0.1:5602
	config_get interval_ms "$section" interval_ms 1000
	config_get count "$section" count 0

	procd_open_instance "$section"
	procd_set_param command /usr/sbin/omega4-linkd --mode "$mode" --iface "$iface" --freq "$freq" --ht-mode "$ht_mode" --stream "$stream"
	[ "$setup" -eq 1 ] && procd_append_param command --setup
	[ "$mode" = "tx" ] && procd_append_param command --udp-listen "$udp_listen"
	[ "$mode" = "rx" ] && procd_append_param command --udp-dest "$udp_dest"
	[ "$mode" = "ping" ] && procd_append_param command --interval-ms "$interval_ms"
	[ "$mode" = "ping" ] && [ "$count" -gt 0 ] && procd_append_param command --count "$count"
	procd_set_param respawn 5 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

start_mavlink_instance() {
	local section="$1"
	local enabled serial baud udp_listen udp_dest verbose

	config_get_bool enabled "$section" enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get serial "$section" serial /dev/ttyS1
	config_get baud "$section" baud 57600
	config_get udp_listen "$section" udp_listen 14552
	config_get udp_dest "$section" udp_dest 127.0.0.1:14551
	config_get_bool verbose "$section" verbose 0

	procd_open_instance "$section"
	procd_set_param command /usr/sbin/omega4-mavlinkd --serial "$serial" --baud "$baud" --udp-listen "$udp_listen" --udp-dest "$udp_dest"
	[ "$verbose" -eq 1 ] && procd_append_param command --verbose
	procd_set_param respawn 5 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

start_video_instance() {
	local section="$1"
	local enabled role iface setup freq ht_mode stream udp_listen udp_dest rtsp_url rtsp_latency rtsp_protocols verbose

	config_get_bool enabled "$section" enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get role "$section" role ground
	config_get iface "$section" iface wlan0
	config_get_bool setup "$section" setup 0
	config_get freq "$section" freq 5180
	config_get ht_mode "$section" ht_mode HT20
	config_get stream "$section" stream 1
	config_get udp_listen "$section" udp_listen 5601
	config_get udp_dest "$section" udp_dest 127.0.0.1:5600
	config_get rtsp_url "$section" rtsp_url
	config_get rtsp_latency "$section" rtsp_latency 50
	config_get rtsp_protocols "$section" rtsp_protocols tcp
	config_get_bool verbose "$section" verbose 0

	procd_open_instance "$section"
	procd_set_param command /usr/sbin/omega4-videod --role "$role" --iface "$iface" --freq "$freq" --ht-mode "$ht_mode" --stream "$stream"
	[ "$setup" -eq 1 ] && procd_append_param command --setup
	[ "$role" = "air" ] && procd_append_param command --udp-listen "$udp_listen"
	[ "$role" = "air" ] && [ -n "$rtsp_url" ] && procd_append_param command --rtsp-url "$rtsp_url" --rtsp-latency "$rtsp_latency" --rtsp-protocols "$rtsp_protocols"
	[ "$role" = "ground" ] && procd_append_param command --udp-dest "$udp_dest"
	[ "$verbose" -eq 1 ] && procd_append_param command --verbose
	procd_set_param respawn 5 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

start_service() {
	config_load omega4-link
	config_foreach start_link_instance omega4-link
	config_foreach start_mavlink_instance omega4-mavlink
	config_foreach start_video_instance omega4-video
}
